<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mvp.mapper.UserMapper">

    <select id="selectLoginUser" resultType="com.mvp.entity.User">
        select * from user where user_name = #{userName} and status = 0
    </select>
</mapper>
